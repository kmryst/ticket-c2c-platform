{
  "name": "ticket-c2c-platform",
  "version": "0.1.0",
  "private": true,
  "description": "C2C ticket platform architecture and local PoC workspace.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "start:dev": "ts-node src/main.ts",
    "poc:inventory": "ts-node --project tsconfig.scripts.json scripts/poc/inventory-purchase-poc.ts",
    "start:worker": "node dist/src/worker.js",
    "worker:dev": "ts-node src/worker.ts",
    "commitlint": "commitlint",
    "lint:md": "markdownlint-cli2",
    "test": "jest",
    "smoke:staging": "ts-node --project tsconfig.scripts.json scripts/staging/smoke-test.ts",
    "smoke:dev": "ts-node --project tsconfig.scripts.json scripts/staging/smoke-test.ts",
    "migration:run": "node dist/src/database/run-migrations.js",
    "migration:run:local": "ts-node src/database/run-migrations.ts",
    "migration:create": "typeorm migration:create"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.1079.0",
    "@aws-sdk/client-secrets-manager": "^3.1084.0",
    "@aws-sdk/client-sqs": "^3.1089.0",
    "@aws-sdk/credential-provider-node": "^3.972.62",
    "@fastify/cookie": "^11.1.2",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.28",
    "@opensearch-project/opensearch": "^3.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/id-generator-aws-xray": "^2.1.0",
    "@opentelemetry/instrumentation-aws-sdk": "^0.75.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/instrumentation-ioredis": "^0.68.0",
    "@opentelemetry/instrumentation-pg": "^0.72.0",
    "@opentelemetry/propagator-aws-xray": "^2.2.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "jest": "^30.4.2",
    "markdownlint-cli2": "^0.23.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
