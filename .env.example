POSTGRES_DB=ticket_poc
POSTGRES_USER=ticket_poc
POSTGRES_PASSWORD=ticket_poc_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql://ticket_poc:ticket_poc_password@localhost:5432/ticket_poc

VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379

# --- dev 環境向けのオプション設定（未設定ならローカル PoC 挙動） ---
# DATABASE_URL の代わりに分解値でも指定できる（dev では Secrets Manager から注入）
# DB_HOST=
# DB_PORT=5432
# DB_NAME=ticket
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSL=true
# EventBridge ドメインイベント発行（未設定なら no-op）
# EVENT_BUS_NAME=
# OpenSearch 検索（未設定なら DB フォールバック）
# OPENSEARCH_ENDPOINT=
# Worker 用 SQS キュー
# SQS_QUEUE_URL=
# スキーマ適用は起動時ではなく TypeORM migrations で行う（Issue #92）
# ローカル: npm run migration:run:local / AWS: db-migrate workflow

# JWT 署名シークレット（ADR-0010）。ローカル PoC 用の値なので本番系では使わない。
# dev / staging では Secrets Manager から ECS タスクへ注入される（Issue #134）
JWT_SECRET=local-poc-jwt-secret-change-me

# 認証系レート制限（ADR-0012 / Issue #167）。ローカル PoC は既定値のままでよい。
# RATE_LIMIT_TRUSTED_PROXY_HOPS: X-Forwarded-For の末尾で信用するプロキシ段数（AWS: CloudFront→ALB で 1、ローカル: 0）
# AUTH_RATE_LIMIT_WINDOW_SECONDS: 固定ウィンドウ幅（既定 900 秒）
# AUTH_RATE_LIMIT_{SIGNUP|LOGIN|REFRESH}_{IP|SECONDARY}: ウィンドウあたり許容回数の上書き
# RATE_LIMIT_TRUSTED_PROXY_HOPS=0
