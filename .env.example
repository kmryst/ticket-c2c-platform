POSTGRES_DB=ticket_poc
POSTGRES_USER=ticket_poc
POSTGRES_PASSWORD=ticket_poc_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql://ticket_poc:ticket_poc_password@localhost:5432/ticket_poc

VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379

# --- dev 環境向けのオプション設定（未設定ならローカル PoC 挙動） ---
# DATABASE_URL の代わりに分解値でも指定できる（dev では Secrets Manager から注入）
# DB_HOST=
# DB_PORT=5432
# DB_NAME=ticket
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSL=true
# EventBridge ドメインイベント発行（未設定なら no-op）
# EVENT_BUS_NAME=
# OpenSearch 検索（未設定なら DB フォールバック）
# OPENSEARCH_ENDPOINT=
# Worker 用 SQS キュー
# SQS_QUEUE_URL=
# スキーマ適用は起動時ではなく TypeORM migrations で行う（Issue #92）
# ローカル: npm run migration:run:local / AWS: db-migrate workflow
